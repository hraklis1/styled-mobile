{
  "expo": {
    "name": "Styled",
    "slug": "Styled-mobile",
    "scheme": "styled",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ttrypho.Styled-mobile",
      "buildNumber": "1",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSCameraUsageDescription": "Styled needs camera access to photograph your clothing items and add them to your wardrobe.",
        "NSPhotoLibraryUsageDescription": "Styled needs access to your photo library to import clothing images into your wardrobe."
      }
    },
    "android": {
      "package": "com.ttrypho.styledmobile",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": true,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "blockedPermissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "Styled needs access to your photos to add clothing items to your wardrobe.",
          "cameraPermission": "Styled needs camera access to photograph your clothing items."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Styled needs microphone access to record your voice for the AI stylist."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Styled uses your location to identify the store branch for shopping photos and provide weather-aware outfit suggestions."
        }
      ],
      "expo-image",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FAF8F5",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200
        }
      ],
      "expo-font",
      "expo-asset",
      [
        "expo-camera",
        {
          "cameraPermission": "Styled needs camera access to quickly save clothing items and price tags while you shop.",
          "recordAudioAndroid": false,
          "barcodeScannerEnabled": false
        }
      ]
    ]
  }
}
