# Required runtime configuration
# Use localhost only for the iOS simulator. Android emulators use
# http://10.0.2.2:<port>; physical devices need a reachable HTTPS or LAN URL.
# Preview and production EAS environments must always use a hosted HTTPS API.
EXPO_PUBLIC_API_URL=https://api.example.com
EXPO_PUBLIC_SUPABASE_URL=https://example.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Authentication and subscriptions
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_your-key
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_your-key

# Diagnostics
EXPO_PUBLIC_SENTRY_DSN=https://example.ingest.sentry.io/project
EXPO_PUBLIC_POSTHOG_API_KEY=phc_your-key
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Public store-compliance pages
EXPO_PUBLIC_PRIVACY_URL=https://example.com/privacy
EXPO_PUBLIC_TERMS_URL=https://example.com/terms
EXPO_PUBLIC_SUPPORT_URL=https://example.com/support
EXPO_PUBLIC_ACCOUNT_DELETION_URL=https://example.com/delete-account

# Build-only secrets belong in EAS environment variables, never EXPO_PUBLIC_*
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ORG=your-sentry-organization
SENTRY_PROJECT=styled-mobile
